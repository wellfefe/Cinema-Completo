generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Genero {
  ACAO
  COMEDIA
  DRAMA
  TERROR
  ROMANCE
  FICCAO
  ANIMACAO
  OUTRO
}

model Cinema {
  id       Int      @id @default(autoincrement())
  nome     String
  endereco String

  salas    Sala[]
  filmes   Filme[]
  sessoes  Sessao[]
}

model Sala {
  id         Int      @id @default(autoincrement())
  numero     Int
  capacidade Int

  cinemaId   Int
  cinema     Cinema   @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  sessoes    Sessao[]
}

model Filme {
  id                 Int       @id @default(autoincrement())
  titulo             String
  sinopse            String
  classificacao      String
  duracao            Int
  elenco             String
  genero             Genero
  dataInicioExibicao DateTime
  dataFinalExibicao  DateTime

  cinemaId           Int
  cinema             Cinema    @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  sessoes            Sessao[]
}

model Sessao {
  id              Int       @id @default(autoincrement())
  horarioExibicao DateTime

  cinemaId        Int
  cinema          Cinema    @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  filmeId         Int
  filme           Filme     @relation(fields: [filmeId], references: [id], onDelete: Cascade)

  salaId          Int
  sala            Sala      @relation(fields: [salaId], references: [id], onDelete: Cascade)

  ingressos       Ingresso[]
}

model Ingresso {
  id           Int      @id @default(autoincrement())
  valorInteira Float
  valorMeia    Float

  sessaoId     Int
  sessao       Sessao   @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  pedidoId     Int?
  pedido       Pedido?  @relation(fields: [pedidoId], references: [id])
}

model LancheCombo {
  id            Int      @id @default(autoincrement())
  nome          String
  valorUnitario Float
  qtdUnidade    Int
  subtotal      Float

  pedidoId      Int?
  pedido        Pedido?  @relation(fields: [pedidoId], references: [id])
}

model Pedido {
  id         Int           @id @default(autoincrement())
  qInteira   Int
  qMeia      Int
  valorTotal Float

  ingressos  Ingresso[]
  lanches    LancheCombo[]
}